# ─────────────────────────────────────────────
# DevMate v2 — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Required — your DigitalOcean Gradient API key
# Get it from: https://cloud.digitalocean.com/gradient
DO_GRADIENT_API_KEY=
GRADIENT_MODEL_ACCESS_KEY=

# Optional — GitHub personal access token
# Without this you're limited to 60 unauthenticated requests/hour.
# With it: 5000 requests/hour. Needed for large or private repos.
# Create one at: https://github.com/settings/tokens (repo scope only)
GITHUB_TOKEN=
